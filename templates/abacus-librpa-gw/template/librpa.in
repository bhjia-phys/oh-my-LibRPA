# Baseline template: periodic GW + shrink + symmetry lane.
# Do not reuse this file for the short molecular GW route; materialize `routes/molecule-gw-no-nscf-no-pyatb-no-shrink/` instead.
# Do not use the symmetry flags below for SOC cases.
task = g0w0_band
nfreq = 16
option_dielect_func = 3
replace_w_head = t
use_scalapack_gw_wc = t
parallel_routing = libri
vq_threshold = 0
sqrt_coulomb_threshold = 0
use_shrink_abfs = t
# SOC cases should keep these flags disabled.
use_abacus_exx_symmetry = t
use_abacus_gw_symmetry = t
use_fullcoul_exx = t

output_gw_sigc_mat_rf = t

libri_chi0_threshold_C = 1e-4
libri_chi0_threshold_G = 1e-5
libri_exx_threshold_V = 1e-1
libri_exx_threshold_C = 1e-4
libri_exx_threshold_D = 1e-4
libri_g0w0_threshold_C = 1e-5
libri_g0w0_threshold_G = 1e-5
libri_g0w0_threshold_Wc = 1e-6

#debug = t
