INPUT_PARAMETERS
# Baseline template: periodic GW + shrink + symmetry lane.
# Do not reuse this file for the short molecular GW route; materialize `routes/molecule-gw-no-nscf-no-pyatb-no-shrink/` instead.
# Do not use this symmetry-on SCF template for SOC cases; with SOC keep ABACUS on `symmetry -1`.
#Parameters	(General)
pseudo_dir		./
orbital_dir		./
out_mat_xc      1
out_chg		1
out_mat_hs2           1
out_mat_r             1

calculation	scf
ntype			2	
nbands			67
#Parameters (Accuracy)
ecutwfc			130

smearing_method 	gaussian
smearing_sigma		1e-4
basis_type		lcao
latname                 user_defined_lattice
ks_solver  genelpa
dft_functional			pbe
rpa				1
# Symmetry-enabled SCF emits the sidecars consumed by LibRPA.
# SOC cases must not use this lane; keep `symmetry -1` instead.
symmetry			1
exx_separate_loop		1
exx_pca_threshold		10

#exx_v_threshold			0
#exx_c_threshold			0	
#exx_dm_threshold		0	
#exx_schwarz_threshold	0	
#exx_cauchy_threshold	1E-7

exx_singularity_correction     massidda
exx_ccp_rmesh_times	    3
rpa_ccp_rmesh_times     6
exx_real_number         1
shrink_abfs_pca_thr     1e-4
shrink_lu_inv_thr       1e-3
exx_cs_inv_thr              1e-5
