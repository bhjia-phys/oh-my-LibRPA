# Example host profile for a remote HPC environment.
# Replace every placeholder below with values from your own site.
# This file is intentionally generic so the public repo does not embed personal machine details.

OH_MY_LIBRPA_SERVER_NAME=generic-hpc
OH_MY_LIBRPA_PYTHON3_EXEC=/path/to/python3
OH_MY_LIBRPA_ABACUS_EXEC=/path/to/abacus
OH_MY_LIBRPA_LIBRPA_EXEC=/path/to/chi0_main.exe
OH_MY_LIBRPA_MPI_LAUNCHER=mpirun
OH_MY_LIBRPA_MPI_LAUNCHER_CMD=/path/to/mpirun
OH_MY_LIBRPA_ENV_SOURCES='/etc/bashrc;/path/to/mpi-or-oneapi-init.sh'
OH_MY_LIBRPA_MODULE_LOADS='mpi-module-name'
OH_MY_LIBRPA_PATH_PREPEND='/path/to/site/bin:/path/to/python/bin:/path/to/helper/scripts'
OH_MY_LIBRPA_LD_LIBRARY_PATH_PREPEND='/path/to/site/lib:/path/to/site/lib64'
OH_MY_LIBRPA_DEFAULT_MPI_RANKS=4
OH_MY_LIBRPA_DEFAULT_PYATB_MPI_RANKS=1
OH_MY_LIBRPA_DEFAULT_OMP_THREADS=32
